		printf 'eval "$(%s shellenv)"\n' "$_CONF_INSTALL_HOMEBREW_CMD" >>~/.zprofile
		eval "$($_CONF_INSTALL_HOMEBREW_CMD shellenv)"
		return
	fi
	_warn "Homebrew appears to already be installed"
}
